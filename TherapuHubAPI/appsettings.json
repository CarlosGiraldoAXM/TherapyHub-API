{
  "ConnectionStrings": {
    "DefaultConnection": "YOUR_CONNECTION_STRING"
  },
  "Jwt": {
    "Key": "YOUR_JWT_KEY_HERE_MIN_32_CHARS",
    "Issuer": "TherapuHubAPI",
    "Audience": "TherapuHubAPI",
    "ExpirationHours": "24"
  },
  "AzureBlobStorage": {
    "ConnectionString": "YOUR_AZURE_BLOB_CONNECTION_STRING",
    "ContainerName": "therapyhub-files"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "ChatSettings": {
    "MessageEditWindowMinutes": 15
  },
  "AllowedHosts": "*"
}